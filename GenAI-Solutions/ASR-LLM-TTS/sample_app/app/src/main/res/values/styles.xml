
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- App theme -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fab_main_bg</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/toolbar_background_color</item>
    </style>

    <!-- Toolbar style -->
    <style name="Widget.Material3.Toolbar" parent="Widget.Material3.Toolbar" tools:ignore="ResourceCycle">
        <item name="titleTextColor">@color/toolbar_title_color</item>
        <item name="navigationIconTint">@color/toolbar_icon_tint</item>
    </style>

    <!-- TextInputLayout outlined style -->
    <style name="Widget.Material3.TextInputLayout.OutlinedBox" parent="Widget.Material3.TextInputLayout.OutlinedBox" tools:ignore="ResourceCycle">
        <item name="hintTextColor">@color/text_field_hint</item>
        <item name="boxStrokeColor">@color/text_field_stroke</item>
    </style>

    <!-- FAB styles -->
    <style name="Widget.Material3.FloatingActionButton" parent="Widget.Material3.FloatingActionButton" tools:ignore="ResourceCycle">
        <item name="tint">@color/white</item>
    </style>

    <style name="Widget.Material3.ExtendedFloatingActionButton" parent="Widget.Material3.ExtendedFloatingActionButton" tools:ignore="ResourceCycle">
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
